# GeoResearchAgent-247 — Environment Variables
# Copy this file to .env and fill in your keys.
# Never commit .env to git.
#
# Quick start:
#   cp .env.example .env
#   python launch.py
#
# ─── Backend Choice ───────────────────────────────────────────────────────────
#
# Option 1: Anthropic API (direct API calls, full autonomous pipeline)
#   Set ANTHROPIC_API_KEY below, then:
#     python launch.py --backend api
#
# Option 2: Claude Code subscription (no API key needed)
#   Leave ANTHROPIC_API_KEY blank or unset, then:
#     python launch.py --backend claude-code
#   Or just open this folder in Claude Code / VS Code with the Claude extension.
#
# ─── Required for API mode ────────────────────────────────────────────────────

ANTHROPIC_API_KEY=sk-ant-api03-...

# ─── Optional: Semantic Scholar (higher rate limits without it, just slower) ──
# Get a key at: https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_KEY=

# ─── Optional: OpenAI key for Codex hybrid mode ───────────────────────────────
# Required only if running: python launch.py --backend api --mode codex
# Uses GPT-4o (or o3) as parallel coding workers via codex_hybrid.yaml
OPENAI_API_KEY=

# ─── Optional: Brave Search API for web-augmented literature search ───────────
# Used by the brave_search MCP server in .mcp.json
BRAVE_SEARCH_API_KEY=

# ─── Optional: Slack webhook for notifications ────────────────────────────────
# Used by harness/hooks/notification.sh
SLACK_WEBHOOK_URL=

# ─── Optional: project base directory override ────────────────────────────────
# GEO_AGENT_BASE_DIR=/path/to/geo_research_agent_247

# ─── Session settings (set by launcher — can override manually) ───────────────
# GEO_AGENT_SESSION_ID=my_session_001
# GEO_AGENT_CHECKPOINT_DIR=.checkpoints
# GEO_AGENT_LOG_DIR=harness/logs
